{
  "name": "agentport",
  "version": "0.1.0",
  "description": "Portable config compiler for AI coding tools",
  "type": "module",
  "bin": {
    "agentport": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.js",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "agents",
    "cursor",
    "claude",
    "codex",
    "opencode",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
